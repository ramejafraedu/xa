# =============================================================================
# VIDEO FACTORY V14 — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ── AI / Inference ──────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE
INFERENCE_API_URL=https://models.inference.ai.azure.com/chat/completions
INFERENCE_MODEL=gpt-4.1
INFERENCE_FALLBACK_MODEL=gpt-4.1
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=video_factory

# ── Gemini / Google Models ──────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_KEY
GEMINI_API_KEY2=
GEMINI_API_KEY3=
GEMINI_API_KEY4=
GEMINI_API_KEY_BACKUP=
# Optional alias used by this project when GEMINI_TEXT_MODEL is not set
PRIMARY_LLM=gemini-3.1-pro-preview
GEMINI_CHAT_MODELS=gemini-3.1-pro-preview,gemini-2.5-pro,gemini-2.5-flash,gemini-2.0-flash-001
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview
# 3.1 Pro Preview is text-only; keep a multimodal model for vision tasks
GEMINI_VISION_MODEL=gemini-2.5-pro
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
IMAGE_GENERATION_MODEL=gemini-2.0-flash-preview-image-generation
GEMINI_KEY_COOLDOWN_SECONDS=25
GEMINI_MODEL_COOLDOWN_SECONDS=600
GEMINI_ENABLE_USAGE_STATS=true

# Vertex AI (optional, opt-in)
USE_VERTEX_AI=false
VERTEX_PROJECT_ID=
# Use global for Gemini 3.1 compatibility in Vertex.
VERTEX_LOCATION=global

# Optional ADC path (service account JSON) for Google SDKs
GOOGLE_APPLICATION_CREDENTIALS=

# ── ElevenLabs TTS (optional paid provider) ────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_API_URL=https://api.elevenlabs.io/v1/text-to-speech
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.75

# ── Google Cloud TTS (optional premium provider) ───────────────────────────
USE_GOOGLE_TTS=false
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_SERVICE_ACCOUNT_JSON=
GOOGLE_TTS_VOICE_NAME=es-US-Neural2-A
GOOGLE_TTS_LANGUAGE_CODE=es-US
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0
GOOGLE_TTS_TIMEOUT_SECONDS=45

# ── Piper TTS (optional offline fallback) ───────────────────────────────────
USE_PIPER_TTS=false
PIPER_MODEL_PATH=
TTS_USE_SCRIPT_TEXT=true
SUBTITLES_USE_SCRIPT_TEXT=true

# ── Pexels (up to 4 keys for rotation) ──────────────────────────────────────
PEXELS_API_KEY=YOUR_KEY_1
PEXELS_API_KEY2V=YOUR_KEY_2
PEXELS_API_KEY3V=YOUR_KEY_3
PEXELS_API_KEY4V=YOUR_KEY_4

# ── Pixabay ─────────────────────────────────────────────────────────────────
PIXABAY_API_KEY=YOUR_PIXABAY_KEY

# ── Music ───────────────────────────────────────────────────────────────────
JAMENDO_CLIENT_ID=YOUR_JAMENDO_ID
SUNO_API_KEY=
SUNO_API_URL=https://api.sunoapi.org/api/v1/generate
SUNO_STATUS_API_URL=

# ── AssemblyAI (subtitles) ──────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=YOUR_ASSEMBLYAI_KEY

# ── Freesound (SFX) ────────────────────────────────────────────────────────
FREESOUND_API_KEY=YOUR_FREESOUND_KEY

# ── Image Gen ───────────────────────────────────────────────────────────────
POLLINATIONS_BASE=https://image.pollinations.ai
LEONARDO_API_KEY=YOUR_LEONARDO_KEY
PREFER_STOCK_IMAGES=true

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── Supabase (optional) ────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_VIDEOS_TABLE=videos
SUPABASE_PERFORMANCE_TABLE=video_performance

# ── Google Drive/Sheets (optional — set USE_DRIVE=true to enable) ──────────
USE_DRIVE=false
GOOGLE_DRIVE_FOLDER_ID=root
GOOGLE_SHEETS_ID=YOUR_SHEET_ID
# Place google_credentials.json (Service Account) in this directory

# ── TikTok Trending (optional) ──────────────────────────────────────────────
RAPIDAPI_KEY=YOUR_RAPIDAPI_KEY
ENABLE_TIKTOK_TRENDING_API=false

# ── Rollout Flags (V16) ─────────────────────────────────────────────────────
FREE_MODE=false
ALLOW_FREEMIUM_IN_FREE_MODE=true
USE_LYRIA_MUSIC=true
USE_SUNO_MUSIC=true
USE_VEO_CLIPS=false
USE_REMOTION=true
FORCE_FFMPEG_RENDERER=false
ENABLE_WEB_RESEARCH_PLUS=false
ENABLE_REFERENCE_DRIVEN=false
ENABLE_COST_GOVERNANCE=false

# OpenMontage free-tools integration (V15)
ENABLE_OPENMONTAGE_FREE_TOOLS=true
OPENMONTAGE_ROOT_DIR=OpenMontage-main
OPENMONTAGE_DEFAULT_PLAYBOOK=clean-professional
OPENMONTAGE_ENABLE_STYLES=true
OPENMONTAGE_ENABLE_ANALYSIS=true
OPENMONTAGE_ENABLE_SUBTITLE=true
OPENMONTAGE_ENABLE_ENHANCEMENT=false
OPENMONTAGE_ENABLE_VIDEO_UTILITIES=false
V15_STRICT_FREE_MEDIA_TOOLS=true

# Optional niche templates file (JSON) to override hardcoded NICHOS
NICHES_CONFIG_PATH=

# Scheduler canary rollout
SCHEDULER_CANARY_MODE=false
SCHEDULER_CANARY_NICHOS=finanzas
SCHEDULER_USE_V15=true

# Budget governance (USD per day)
DAILY_BUDGET_USD=0

# Monthly cap for freemium mode (USD)
MONTHLY_BUDGET_USD=1

# Stage-level estimates for governance (USD)
EST_COST_RESEARCH_USD=0
EST_COST_SCRIPT_USD=0
EST_COST_SCENE_USD=0
EST_COST_ASSETS_USD=0.10
EST_COST_TTS_USD=0.03
EST_COST_RENDER_USD=0

# ── Workspace ───────────────────────────────────────────────────────────────
# Leave as ./ for relative paths (recommended)
WORKSPACE_DIR=./workspace
# Max days to keep output videos (0 = keep forever)
OUTPUT_RETENTION_DAYS=0
# Minimum free disk space in GB before aborting
MIN_DISK_SPACE_GB=2
# Media cache TTL in days (videos/images reuse by keyword/prompt)
MEDIA_CACHE_TTL_DAYS=7
# Generated images per video (used by renderer for richer visual variety)
GENERATED_IMAGES_COUNT=6

# ── Hashtags ────────────────────────────────────────────────────────────────
DEFAULT_HASHTAGS=#viral #fyp #faceless

# ── Public URL (recommended HTTPS domain, no IP) ───────────────────────────
# Example: https://video.tu-dominio.com
PUBLIC_APP_URL=
