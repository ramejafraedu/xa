# =============================================================================
# VIDEO FACTORY V14 — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ── AI / Inference ──────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE
INFERENCE_API_URL=https://models.inference.ai.azure.com/chat/completions
INFERENCE_MODEL=gpt-4.1
INFERENCE_FALLBACK_MODEL=gpt-4.1

# ── Gemini TTS ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_KEY

# ── Pexels (up to 4 keys for rotation) ──────────────────────────────────────
PEXELS_API_KEY=YOUR_KEY_1
PEXELS_API_KEY2V=YOUR_KEY_2
PEXELS_API_KEY3V=YOUR_KEY_3
PEXELS_API_KEY4V=YOUR_KEY_4

# ── Pixabay ─────────────────────────────────────────────────────────────────
PIXABAY_API_KEY=YOUR_PIXABAY_KEY

# ── Music ───────────────────────────────────────────────────────────────────
JAMENDO_CLIENT_ID=YOUR_JAMENDO_ID

# ── AssemblyAI (subtitles) ──────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=YOUR_ASSEMBLYAI_KEY

# ── Freesound (SFX) ────────────────────────────────────────────────────────
FREESOUND_API_KEY=YOUR_FREESOUND_KEY

# ── Image Gen ───────────────────────────────────────────────────────────────
POLLINATIONS_BASE=https://image.pollinations.ai
LEONARDO_API_KEY=YOUR_LEONARDO_KEY

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── Supabase (optional) ────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Google Drive/Sheets (optional — set USE_DRIVE=true to enable) ──────────
USE_DRIVE=false
GOOGLE_DRIVE_FOLDER_ID=root
GOOGLE_SHEETS_ID=YOUR_SHEET_ID
# Place google_credentials.json (Service Account) in this directory

# ── TikTok Trending (optional) ──────────────────────────────────────────────
RAPIDAPI_KEY=YOUR_RAPIDAPI_KEY

# ── Workspace ───────────────────────────────────────────────────────────────
# Leave as ./ for relative paths (recommended)
WORKSPACE_DIR=./workspace
# Max days to keep output videos (0 = keep forever)
OUTPUT_RETENTION_DAYS=0
# Minimum free disk space in GB before aborting
MIN_DISK_SPACE_GB=2

# ── Hashtags ────────────────────────────────────────────────────────────────
DEFAULT_HASHTAGS=#viral #fyp #faceless
